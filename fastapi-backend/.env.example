OPENAI_API_KEY=your_apimart_api_key
OPENAI_BASE_URL=https://api.apimart.ai/v1
OPENAI_IMAGE_MODEL=gpt-image-2
PYTHON_VERSION=3.11.9

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_TEMPLATE_BUCKET=lumina-templates

SESSION_TTL_DAYS=30
SESSION_TOKEN_BYTES=32
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Drmina AI <onboarding@resend.dev>
PASSWORD_RESET_BASE_URL=http://localhost:3001
PASSWORD_RESET_EXPIRE_MINUTES=30

# Local development:
# DATABASE_URL=sqlite+aiosqlite:///./lumina.db
#
# Supabase PostgreSQL production example:
# DATABASE_URL=postgresql+asyncpg://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite+aiosqlite:///./lumina.db

CORS_ORIGINS=http://localhost:3001,https://your-vercel-domain.vercel.app
FREE_MONTHLY_QUOTA=5
PRO_MONTHLY_QUOTA=500
VIP1_IMAGE_QUOTA=50
VIP2_IMAGE_QUOTA=100
VIP3_IMAGE_QUOTA=500
VIP1_PRICE=9.9
VIP2_PRICE=19.9
VIP3_PRICE=99.9
PROMO_VIP2_BONUS_QUOTA=50

# Required in production. Payment callbacks sign:
# hex(hmac_sha256(PAYMENT_WEBHOOK_SECRET, "{orderId}.{paymentStatus}.{timestamp}"))
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
PAYMENT_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Configure exactly one private admin identity for /admin access.
ADMIN_EMAIL=admin@example.com
# ADMIN_PHONE=
# ADMIN_USER_ID=
