OPENAI_API_KEY=replace_with_apimart_key
OPENAI_BASE_URL=https://api.apimart.ai/v1
OPENAI_IMAGE_MODEL=gpt-image-2
APIMART_POLL_INTERVAL_SECONDS=4
APIMART_MAX_WAIT_SECONDS=300

# MVP on one ECS can start with SQLite. The compose file stores it in a Docker volume.
DATABASE_URL=sqlite+aiosqlite:////data/drmine.db

CORS_ORIGINS=http://47.76.44.89
SESSION_TTL_DAYS=30
SESSION_TOKEN_BYTES=32
FREE_MONTHLY_QUOTA=5
PRO_MONTHLY_QUOTA=500
VIP1_IMAGE_QUOTA=50
VIP2_IMAGE_QUOTA=100
VIP3_IMAGE_QUOTA=500
VIP1_PRICE=9.9
VIP2_PRICE=19.9
VIP3_PRICE=99.9
PROMO_VIP2_BONUS_QUOTA=50
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
PAYMENT_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Optional. Required only if you want password reset emails to actually send.
RESEND_API_KEY=
EMAIL_FROM=Drmina AI <onboarding@resend.dev>
PASSWORD_RESET_BASE_URL=http://47.76.44.89
PASSWORD_RESET_EXPIRE_MINUTES=30

# Optional. Required only for template image storage / generation scripts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TEMPLATE_BUCKET=lumina-templates
